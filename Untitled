#include "types.h"
#include "stat.h"
#include "user.h"

int
main(void)
{
  int pid1, pid2;

  pid1 = fork();
  if(pid1 < 0){
    printf(1, "fork 1 failed\n");
    exit();
  }

  if(pid1 == 0){
    printf(1, "Child 1 Executing\n");
    exit();
  }

  pid2 = fork();
  if(pid2 < 0){
    printf(1, "fork 2 failed\n");
    exit();
  }

  if(pid2 == 0){
    printf(1, "Child 2 Executing\n");
    exit();
  }

  wait();
  wait();

  printf(1, "Parent Executing\n");
  exit();
}